{
  "name": "car-dealership-inventory-system",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack Car Dealership Inventory System",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "test": "npm test --prefix backend && npm test --prefix frontend",
    "test:coverage": "npm run test:coverage --prefix backend",
    "seed": "npm run seed --prefix backend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": ["car-dealership", "inventory", "full-stack"],
  "license": "MIT"
}
